# --- Backend (Render) environment variables ---
# Render sets PORT automatically; optional locally.
PORT=3001
NODE_ENV=production

# MySQL for Prisma. Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE[?params]
# - No quotes. Special chars in password must be URL-encoded (@ -> %40, # -> %23, etc.).
# - SSL (required for most cloud MySQL): ?ssl-mode=REQUIRED or ?sslaccept=strict
# Example: mysql://user:myp%40ss@host.example.com:3306/dbname?ssl-mode=REQUIRED
DATABASE_URL=mysql://user:password@host:3306/dbname?ssl-mode=REQUIRED

JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# Comma-separated frontend origins (no trailing slash). After Vercel deploy, set to your Vercel URL.
CORS_ORIGIN=http://localhost:3000

# Optional: cookie domain for shared subdomain (e.g. .yourdomain.com). Leave empty for same-origin.
COOKIE_DOMAIN=
COOKIE_NAME=refreshToken

# Optional: email that can access Admin > Add Course
ADMIN_EMAIL=
