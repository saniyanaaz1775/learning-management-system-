PORT=3001
# MySQL URL for Prisma. Required format: mysql://USER:PASSWORD@HOST:PORT/DATABASE[?params]
# - No surrounding quotes (in Render/Vercel, paste the value without quotes).
# - Use mysql:// only (not jdbc:mysql://). Special chars in password must be URL-encoded (e.g. @ -> %40).
# - SSL example: mysql://user:password@host:3306/dbname?ssl-mode=REQUIRED&sslaccept=strict
DATABASE_URL=mysql://user:password@host:3306/dbname?ssl-mode=REQUIRED&sslaccept=strict
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret
CORS_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=
COOKIE_NAME=refreshToken
# Admin Add Course: set to the email of the user who can create courses (e.g. admin@example.com)
ADMIN_EMAIL=saniya1234@gmail.com
