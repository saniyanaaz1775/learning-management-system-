PORT=3001
# Aiven MySQL (SSL required). Include both ssl-mode=REQUIRED and sslaccept.
# Production: sslaccept=strict. Local Windows (if P1011 cert not trusted): sslaccept=accept_invalid_certs
# DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl-mode=REQUIRED&sslaccept=strict"
DATABASE_URL="mysql://user:password@host:3306/dbname?ssl-mode=REQUIRED&sslaccept=strict"
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret
CORS_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=
COOKIE_NAME=refreshToken
